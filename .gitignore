/.idea/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Generati da proto/gossip.proto durante il docker build (docker/Dockerfile.worker).
# Non esistono nell'host a meno che non si esegua protoc localmente per l'autocompletamento IDE.
gossip_pb2.py
gossip_pb2_grpc.py

# Dataset scaricato separatamente con scripts/download_femnist.py
data/
leaf/

# Log e variabili d'ambiente
*.log
.env

# Compose file generato da scripts/generate_compose.py — non versionare
/docker-compose.yml

# Model checkpoints negli esperimenti — file binari pesanti (~6.6 MB ciascuno).
# Si versionano solo CSV, PNG, log e summary; i .pt si rigenerano rieseguendo il run.
results/**/*.pt

# Terraform — generated files (contain IPs and sensitive state)
terraform/.terraform/
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfvars
terraform/.terraform.lock.hcl
terraform/single/.terraform/
terraform/single/terraform.tfstate
terraform/single/terraform.tfstate.backup
terraform/single/terraform.tfvars
terraform/single/.terraform.lock.hcl
/.claude/
